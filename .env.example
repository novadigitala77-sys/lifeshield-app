# ============================================================
#  LifeShield Pro — Variables de Entorno
#  Copia este archivo como .env.local y completa los valores
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Obtenlos en: https://supabase.com > Tu proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── TWILIO (SMS + WhatsApp) ───────────────────────────────────
# Obtenlos en: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15005550006          # Número SMS Twilio
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886  # Sandbox WhatsApp

# ── GOOGLE CALENDAR ───────────────────────────────────────────
# Crear en: https://console.cloud.google.com > APIs > Credentials
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Después de autenticar, guardar este refresh token:
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxx

# ── EMAIL (Resend) ────────────────────────────────────────────
# Obtenlo en: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=LifeShield Pro <noreply@tudominio.com>

# ── APP ───────────────────────────────────────────────────────
NEXTAUTH_SECRET=genera-uno-con-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENT_ZOOM_LINK=https://zoom.us/j/1234567890

# ── CRON SECRET (para proteger endpoints de cron) ─────────────
CRON_SECRET=genera-una-clave-aleatoria-segura
